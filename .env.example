# Server Configuration
PORT=5000
NODE_ENV=production

# Security & CORS Whitelist (Comma-separated list of allowed origins)
ALLOWED_ORIGINS=https://crowdcity.co.in,https://www.crowdcity.co.in

# Supabase Configurations
# Find these in your Supabase Project Settings -> API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# AI API Configurations (For future expansion)
# Get your API key from console.groq.com
GROQ_API_KEY=your-groq-api-key

# Resend API Key for welcome email integration
# RESEND_API_KEY=your-resend-api-key

# Application Base URL
APP_URL=https://crowdcity.co.in
FRONTEND_URL=https://crowdcity.co.in

